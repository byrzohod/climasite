      "items": {
        "sizing": {
          "question": "How do I know what size HVAC system I need?",
          "answer": "The size of your HVAC system depends on several factors including your home's square footage, insulation quality, number of windows, and local climate. A professional can perform a Manual J load calculation to determine the exact size needed. Generally, you need about 20 BTUs per square foot, but this can vary significantly based on your specific situation."
        },
        "maintenance": {
          "question": "How often should I service my HVAC system?",
          "answer": "We recommend having your HVAC system professionally serviced at least twice a year - once in spring before cooling season and once in fall before heating season. Additionally, you should replace or clean your air filters every 1-3 months depending on usage and filter type."
        },
        "efficiency": {
          "question": "What SEER rating should I look for?",
          "answer": "SEER (Seasonal Energy Efficiency Ratio) measures cooling efficiency. The minimum SEER for new systems is 14, but we recommend SEER 16 or higher for optimal efficiency and energy savings. Higher SEER units cost more upfront but provide significant long-term savings on energy bills."
        },
        "warranty": {
          "question": "What warranty do your products come with?",
          "answer": "Most of our HVAC equipment comes with manufacturer warranties ranging from 5 to 10 years on parts. Extended warranties are available for purchase. Professional installation is required to maintain warranty coverage on most products."
        },
        "installation": {
          "question": "Do you offer professional installation services?",
          "answer": "Yes, we partner with certified HVAC technicians across the country to provide professional installation services. Professional installation ensures your system operates at peak efficiency and maintains warranty coverage. Contact us for a free installation quote."
        }
      }
    },
    "cta": {
      "title": "Need More Help?",
      "description": "Our team of HVAC experts is here to answer your questions and help you find the perfect solution.",
      "button": "Contact Us"
    }
